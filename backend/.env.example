# .env.example
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/farm_advisory

# For MongoDB Atlas (example placeholder - DO NOT store real secrets here):
MONGODB_URI=mongodb://<username>:<password>@host:port/dbname?options
# JWT Configuration
JWT_SECRET=change_this_to_a_secure_random_string_in_production

# Farm AI Configuration
# Uses the free local farm advisory engine. No OpenAI API key is required.

# OpenWeatherMap Configuration (get key from https://openweathermap.org/api)
WEATHER_API_KEY=your_weather_api_key

# Gmail SMTP Configuration
# Use a Gmail App Password created from your Google Account security settings.
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Server Configuration
SERVER_PORT=5000

# CORS Configuration (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Spring Profiles
# Use: dev, prod, test
SPRING_PROFILES_ACTIVE=dev
